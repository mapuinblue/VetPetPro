# Backend Configuration

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# Database
DB_PATH=./data/vetpetpro.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Ethereal for development)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=noreply@vetpetpro.com

# Optional: Use environmental email provider
# EMAIL_AUTH_USER=your-email@gmail.com
# EMAIL_AUTH_PASS=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:3001
